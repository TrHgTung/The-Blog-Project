{
  "Routes": [
    {
      "RouteKey": "AuthService",
      "UpstreamPathTemplate": "/api/auth-service/{everything}",
      "UpstreamHttpMethod": ["GET", "POST", "PATCH", "DELETE"],
      "DownstreamPathTemplate": "/api/auth-service/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5230 }
      ]
    },
    {
      "RouteKey": "UserService",
      "UpstreamPathTemplate": "/api/user-service/{everything}",
      "UpstreamHttpMethod": ["GET", "POST", "PATCH", "DELETE"],
      "DownstreamPathTemplate": "/api/user-service/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 5091 }
      ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:5001"
  }
}