{
  "Routes": [
    {
      "RouteKey": "Test-Connection",
      "UpstreamPathTemplate": "/api/test-connection",
      "UpstreamHttpMethod": [ "GET" ],
      "DownstreamPathTemplate": "/api/test-connection",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "localhost", "Port": 4402 }
      ]
    },
    {
      "RouteKey": "Auth-Service",
      "UpstreamPathTemplate": "/api/auth/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PATCH" ],

      "DownstreamPathTemplate": "/api/auth-service/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 4402
        }
      ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:5001"
  }
}
