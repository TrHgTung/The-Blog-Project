{
  "Routes": [
    {
      "RouteKey": "AuthService",
      "UpstreamPathTemplate": "/api/auth-service/{everything}",
      "UpstreamHttpMethod": [
        "GET",
        "POST",
        "PATCH",
        "DELETE"
      ],
      "DownstreamPathTemplate": "/api/auth-service/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5230
        }
      ],
      "RateLimitOptions": {
        "ClientWhitelist": [],
        "EnableRateLimiting": true,
        "Period": "1m",
        "PeriodTimespan": 1,
        "Limit": 10
      }
    },
    {
      "RouteKey": "UserService",
      "UpstreamPathTemplate": "/api/user-service/{everything}",
      "UpstreamHttpMethod": [
        "GET",
        "POST",
        "PATCH",
        "DELETE"
      ],
      "DownstreamPathTemplate": "/api/user-service/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5091
        }
      ],
      "RateLimitOptions": {
        "ClientWhitelist": [],
        "EnableRateLimiting": true,
        "Period": "1m",
        "PeriodTimespan": 1,
        "Limit": 60
      }
    },
    {
      "RouteKey": "ChatServiceHub",
      "UpstreamPathTemplate": "/chatHub/{everything}",
      "DownstreamPathTemplate": "/chatHub/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5017
        }
      ],
      "RateLimitOptions": {
        "ClientWhitelist": [],
        "EnableRateLimiting": true,
        "Period": "1m",
        "PeriodTimespan": 1,
        "Limit": 50
      }
    },
    {
      "RouteKey": "RecommendPostService",
      "UpstreamPathTemplate": "/api/recommend-service/{everything}",
      "UpstreamHttpMethod": [
        "GET",
        "POST",
        "PATCH",
        "DELETE"
      ],
      "DownstreamPathTemplate": "/api/recommend-service/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5051
        }
      ],
      "RateLimitOptions": {
        "ClientWhitelist": [],
        "EnableRateLimiting": true,
        "Period": "1m",
        "PeriodTimespan": 1,
        "Limit": 100
      }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5001",
    "RateLimitOptions": {
      "DisableRateLimitHeaders": false,
      "QuotaExceededMessage": "Too many requests. Please try again later.",
      "HttpStatusCode": 429,
      "ClientIdHeader": "ClientId"
    }
  }
}